# Copy to .env (the .env file is gitignored). Required by the TEST SUITE
# — NOT the app (run the app separately).
#
# ⚠️ NEVER put the real secret in THIS file — it is committed/published.
#    Put real values in .env (gitignored). This file is only a template.
#
# JWT_SECRET must MATCH the running POS app's JWT_SECRET, because the suite mints
# its own valid session tokens to get past the app's auth middleware without a DB
# user. See README → "Technique 1: minting a JWT to bypass auth".
JWT_SECRET=use_the_same_secret_as_the_running_app

# Real account used by backend (real-DB) specs and Postman.
LOGIN_USER=admin
LOGIN_PASS=admin123

# Optional: override the app URL (defaults to http://localhost:3000)
# PW_BASE_URL=http://localhost:3000
